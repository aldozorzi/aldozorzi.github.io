---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const articles = (
  await getCollection("articles", ({ data }) => data.draft !== true)
).sort((a, b) => {
  const aTime = a.data.date?.getTime() ?? 0;
  const bTime = b.data.date?.getTime() ?? 0;
  return bTime - aTime;
});

const getArticleSlug = (id: string) => id.replace(/\.md$/, "");
---

<Layout title="Articles">
  <h1>Articles</h1>
  {
    articles.length === 0 ? (
      <p>
        Nessun articolo trovato.
      </p>
    ) : (
      <ul class="not-prose list-none p-0 m-0 space-y-8">
        {articles.map((article) => (
          <li>
            <a
              class="not-prose font-sans block text-xl md:text-2xl font-semibold tracking-tight text-gray-900 no-underline hover:underline underline-offset-4"
              href={`/articles/${getArticleSlug(article.id)}/`}
            >
              {article.data.title}
            </a>
            {article.data.description && (
              <p class="mt-1 text-base md:text-lg font-normal text-gray-600">
                {article.data.description}
              </p>
            )}
          </li>
        ))}
      </ul>
    )
  }
</Layout>
