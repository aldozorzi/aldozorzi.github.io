---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Page not found">
  <h1>404</h1>
  <p class="mt-4">Page not found.</p>
  <p class="mt-8">
    <a
      class="font-sans text-gray-700 text-sm md:text-base font-semibold uppercase tracking-[0.05em] hover:text-gray-900 transition-colors"
      href="/"
