---
import "../styles/global.css";

interface Props {
  title?: string;
  showArticlesLink?: boolean;
}

const { title = "LDAZRZ", showArticlesLink = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-gray-100">
    <section
      class="min-h-screen py-10 md:py-16 flex flex-col items-center justify-center-safe"
    >
      <div class="container max-w-screen-xl mx-auto px-4">
        <div class="text-center tracking-tight">
          <h6 class="font-medium text-gray-600 text-lg md:text-2xl uppercase mb-8">
            <a class="text-inherit no-underline hover:text-inherit" href="/">
              LDA ZRZ
            </a>
          </h6>

          <div
            class="prose prose-gray prose-lg max-w-none prose-h1:font-normal prose-h2:font-normal prose-h3:font-normal prose-h4:font-normal prose-h5:font-normal prose-h6:font-normal prose-h2:mt-8 prose-h2:mb-3 prose-ul:list-disc prose-ul:pl-6 prose-li:marker:text-gray-700"
          >
            <slot />
          </div>

          {
            showArticlesLink && (
              <p class="mt-12">
                <a
                  class="font-sans text-gray-700 text-sm md:text-base font-semibold uppercase tracking-[0.05em] hover:text-gray-900 transition-colors"
                  href="/articles"
                >
                  articles
                </a>
              </p>
            )
          }
        </div>
      </div>
    </section>
  </body>
</html>
